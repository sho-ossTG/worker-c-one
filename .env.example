# Worker identity — set a unique value per deployment (e.g. worker-c1, worker-c2)
# If not set, all responses will report worker_id: "worker" (default fallback).
WORKER_ID=worker-c1

# Server B base URL used by the worker status page connectivity check (pings /api/health)
# Example: https://your-server-b.vercel.app
SERVER_B_URL=
