# Worker identity — set a unique value per deployment (e.g. worker-c1, worker-c2)
# If not set, all responses will report worker_id: "worker" (default fallback).
WORKER_ID=worker-c1

# ─────────────────────────────────────────────────────────
# WARNING: If WORKER_SECRET is empty, /resolve has no authentication.
# Anyone who knows the worker URL can call /resolve freely.
# Set this to a long random string before sharing the URL with Server B.
# ─────────────────────────────────────────────────────────
WORKER_SECRET=change-this-to-a-random-secret
